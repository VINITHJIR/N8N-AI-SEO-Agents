        "query": "INSERT INTO competitor_backlinks (\n    competitor_id,\n    backlink_source_id,\n    source_url,\n    anchor_text,\n    first_seen_date,\n    last_seen_date,\n    nofollow,\n    status,\n    created_at,\n    updated_at,\n    is_analyzed\n)\nVALUES (\n    '{{ $json.competitor_id.trim() }}',\n    '{{ $json.backlink_source_id.trim() }}',\n    '{{ $json.source_url.replace(/'/g, \"''\") }}',\n    '{{ $json.anchor_text.replace(/'/g, \"''\") }}',\n      NOW(),\n       NOW(),\n  {{ $json.nofollow }},\n    'ACTIVE',\n    NOW(),\n    NOW(),\n    false\n)\nON CONFLICT (competitor_id, backlink_source_id)\nDO UPDATE\nSET\n    last_seen_date = EXCLUDED.last_seen_date,\n    updated_at = NOW(),\n    status = 'ACTIVE';",
