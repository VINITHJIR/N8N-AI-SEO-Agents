        "jsCode": "const backlinks = $json.backlinks || [];\n\nreturn backlinks.map(link => ({\n  json: {\n    competitor_domain: $('Loop Over Items').item.json.domain,\n\n    source_domain: link.url_from\n      .replace('https://', '')\n      .replace('http://', '')\n      .split('/')[0],\n\n    source_url: link.url_from,\n    target_url: link.url_to,\n    anchor_text: link.anchor,\n\n    nofollow: link.nofollow,\n\n    inlink_rank: link.inlink_rank,\n    domain_inlink_rank: link.domain_inlink_rank,\n\n    first_seen: link.first_seen,\n    last_visited: link.last_visited,\n\n    category: 'UNKNOWN'\n  }\n}));"
