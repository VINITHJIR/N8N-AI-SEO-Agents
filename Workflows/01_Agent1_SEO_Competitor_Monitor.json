        "operation": "executeQuery",
        "query": "INSERT INTO competitor_backlinks (\n    competitor_id,\n    backlink_source_id,\n    source_url,\n    anchor_text,\n    nofollow,\n    first_seen_date,\n    last_seen_date,\n    is_analyzed,\n    status,\n    created_at,\n    updated_at\n)\nVALUES (\n    '{{ $json.competitor_id }}',\n    '{{ $json.backlink_source_id }}',\n    '{{ $json.source_url }}',\n    '{{ $json.anchor_text.replace(/'/g, \"''\") }}',\n    {{ $json.nofollow }},\n    NOW(),\n    NOW(),\n    false,\n    'ACTIVE'::backlinkstatus,\n    NOW(),\n    NOW()\n)\n\nON CONFLICT (competitor_id, backlink_source_id)\n\nDO UPDATE SET\n\n    source_url = EXCLUDED.source_url,\n\n    anchor_text = EXCLUDED.anchor_text,\n\n    nofollow = EXCLUDED.nofollow,\n\n    last_seen_date = NOW(),\n\n    updated_at = NOW()\n\nRETURNING\n    id,\n    competitor_id,\n    backlink_source_id,\n    is_analyzed;",
